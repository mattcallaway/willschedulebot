# ─── Database ──────────────────────────────────────────────
# PostgreSQL connection string
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/willschedulebot"

# ─── Auth ──────────────────────────────────────────────────
# Secret key for JWT signing — generate with: openssl rand -base64 64
JWT_SECRET="CHANGE_ME_use_openssl_rand_base64_64"

# Token expiry (e.g. 8h, 24h, 7d)
JWT_EXPIRES_IN="8h"

# ─── Server ────────────────────────────────────────────────
PORT=4000
NODE_ENV=development

# ─── Frontend (used by Vite) ───────────────────────────────
VITE_API_URL=http://localhost:4000/api
